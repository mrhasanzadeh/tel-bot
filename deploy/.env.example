# tel-bot production — copy to deploy/.env

BOT_TOKEN=

# Shiori API (tel-bot talks to API only — no direct Postgres)
SHIORI_API_URL=https://api.shiori.cloud
BOT_API_TOKEN=

PRIVATE_CHANNEL_ID=
LINKS_CHANNEL_ID=
PUBLIC_CHANNEL_ID=
PUBLIC_CHANNEL_USERNAME=
ADDITIONAL_CHANNEL_ID=
ADDITIONAL_CHANNEL_USERNAME=

ADMIN_USER_ID=
# Archive → private channel auto-copy (default on boot; override with /mirroring)
ARCHIVE_MIRROR_ENABLED=true
PUBLIC_POSTS_CHANNEL_ID=
PACK_FILE_DELETE_MS=120000

# Watchtower (optional)
GHCR_USERNAME=
GHCR_TOKEN=

# Local-only: schedule import scripts still need DATABASE_URL (not used at runtime)
# DATABASE_URL=postgresql://shiori:PASSWORD@host:5432/shiori
