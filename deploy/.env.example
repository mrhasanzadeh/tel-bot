# tel-bot production — copy to deploy/.env

BOT_TOKEN=

# Main Postgres (same DB as shiori-api) — files + file packs
DATABASE_URL=postgresql://shiori:PASSWORD@172.17.0.1:5432/shiori
# Set DATABASE_SSL=true if connecting to a remote managed Postgres with SSL

# Schedule features only (optional until schedule tables move off Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

PRIVATE_CHANNEL_ID=
LINKS_CHANNEL_ID=
PUBLIC_CHANNEL_ID=
PUBLIC_CHANNEL_USERNAME=
ADDITIONAL_CHANNEL_ID=
ADDITIONAL_CHANNEL_USERNAME=

ADMIN_USER_ID=
PUBLIC_POSTS_CHANNEL_ID=
PACK_FILE_DELETE_MS=120000

# Watchtower (optional)
GHCR_USERNAME=
GHCR_TOKEN=
