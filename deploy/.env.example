# Copy to deploy/.env and fill in values:
#   cp .env.example .env

# --- Telegram bot (required) ---
BOT_TOKEN=
PRIVATE_CHANNEL_ID=
# Archive / upload channel (posts copied into PRIVATE_CHANNEL_ID)
LINKS_CHANNEL_ID=-1002509196447
PUBLIC_CHANNEL_ID=
PUBLIC_CHANNEL_USERNAME=
ADDITIONAL_CHANNEL_ID=
ADDITIONAL_CHANNEL_USERNAME=

# --- Supabase (required) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Runtime ---
NODE_ENV=production

# --- Premium custom emoji (optional overrides) ---
# CUSTOM_EMOJI_SUCCESS=
# CUSTOM_EMOJI_ERROR=
# CUSTOM_EMOJI_WARNING=
# CUSTOM_EMOJI_TIMER=
# CUSTOM_EMOJI_BOT=
# CUSTOM_EMOJI_SEARCH=
# CUSTOM_EMOJI_MEGAPHONE=
# CUSTOM_EMOJI_USERS=
# CUSTOM_EMOJI_STOP=
# CUSTOM_EMOJI_INFO=
# CUSTOM_EMOJI_PACKAGE=

# --- Watchtower ---
WATCHTOWER_POLL_INTERVAL=300
# Required on Docker Engine 29+ if watchtower still errors (check: docker version --format '{{.Server.APIVersion}}')
# DOCKER_API_VERSION=1.44

# --- GHCR (only if the package is private) ---
# Create a PAT with read:packages at https://github.com/settings/tokens
# GHCR_USERNAME=mrhasanzadeh
# GHCR_TOKEN=ghp_xxxxxxxxxxxx
