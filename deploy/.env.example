# Copy to deploy/.env and fill in values:
#   cp .env.example .env

# --- Telegram bot (required) ---
BOT_TOKEN=
PRIVATE_CHANNEL_ID=
# Archive / upload channel (posts copied into PRIVATE_CHANNEL_ID)
LINKS_CHANNEL_ID=-1002509196447
PUBLIC_CHANNEL_ID=
PUBLIC_CHANNEL_USERNAME=
ADDITIONAL_CHANNEL_ID=
ADDITIONAL_CHANNEL_USERNAME=

# Schedule release approval
PUBLIC_POSTS_CHANNEL_ID=-1002394982181
# Optional test channel — when set, schedule posts go here (not TheShioriSub)
# SCHEDULE_TEST_CHANNEL_ID=-100xxxxxxxxxx
ADMIN_USER_ID=90344148

# New anime auto-registration defaults (optional)
# SCHEDULE_DEFAULT_STAFF=Dawn
# SCHEDULE_DEFAULT_DONATION_URL=https://t.me/TheShiori/6951

# --- Supabase (required) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Runtime ---
NODE_ENV=production
# Pack files: delete after send completes (default 120000 = 2 minutes)
# PACK_FILE_DELETE_MS=120000

# --- Premium custom emoji (optional overrides) ---
# CUSTOM_EMOJI_SUCCESS=
# CUSTOM_EMOJI_ERROR=
# CUSTOM_EMOJI_WARNING=
# CUSTOM_EMOJI_TIMER=
# CUSTOM_EMOJI_BOT=
# CUSTOM_EMOJI_SEARCH=
# CUSTOM_EMOJI_MEGAPHONE=
# CUSTOM_EMOJI_USERS=
# CUSTOM_EMOJI_STOP=
# CUSTOM_EMOJI_INFO=
# CUSTOM_EMOJI_PACKAGE=

# --- Watchtower ---
WATCHTOWER_POLL_INTERVAL=300
# Required on Docker Engine 29+ if watchtower still errors (check: docker version --format '{{.Server.APIVersion}}')
# DOCKER_API_VERSION=1.44

# --- GHCR (only if the package is private) ---
# Create a PAT with read:packages at https://github.com/settings/tokens
# GHCR_USERNAME=mrhasanzadeh
# GHCR_TOKEN=ghp_xxxxxxxxxxxx
