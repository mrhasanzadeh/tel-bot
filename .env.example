# Local dev only — bypass TLS verify when corporate proxy breaks Node fetch (never on production)
# ALLOW_INSECURE_TLS=1

BOT_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PRIVATE_CHANNEL_ID=
# Archive / upload channel — new posts here are copied (no forward label) into PRIVATE_CHANNEL_ID
LINKS_CHANNEL_ID=-1002509196447
PUBLIC_CHANNEL_ID=
PUBLIC_CHANNEL_USERNAME=
ADDITIONAL_CHANNEL_ID=
ADDITIONAL_CHANNEL_USERNAME=

# Schedule posts (TheShioriSub) — defaults to ADDITIONAL_CHANNEL_ID
PUBLIC_POSTS_CHANNEL_ID=-1002394982181
# Optional: publish schedule posts to a test channel instead (overrides PUBLIC_POSTS_CHANNEL_ID)
# SCHEDULE_TEST_CHANNEL_ID=-100xxxxxxxxxx
ADMIN_USER_ID=90344148

# Rebuild files table from PRIVATE_CHANNEL captions (after accidental DELETE FROM files)
# REINDEX_FROM_ID=1
# REINDEX_TO_ID=4000
# REINDEX_DRY_RUN=1
# REINDEX_DELAY_MS=80

